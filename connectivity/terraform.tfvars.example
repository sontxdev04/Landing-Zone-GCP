# =============================================================================
# connectivity/terraform.tfvars.example — MẪU cấu hình stack connectivity.
# Cách dùng: cp terraform.tfvars.example terraform.tfvars rồi điền giá trị.
# Lưu ý: terraform.tfvars bị .gitignore (KHÔNG commit secret thật).
# =============================================================================

# TF Runner SA cho stack connectivity (giữ nguyên nếu dùng SEED_PROJECT mặc định).
tf_runner_sa = "sa-tf-conn-001@gcp-platform-bootstrap-001.iam.gserviceaccount.com"

# VPN (TÙY CHỌN) — để trống toàn bộ 4 giá trị + [] để bỏ qua tài nguyên VPN.
# KHÔNG commit shared secret thật.
onprem_vpn_public_ip_0 = ""   # IP công khai gateway on-prem #1
onprem_vpn_public_ip_1 = ""   # IP công khai gateway on-prem #2
vpn_shared_secret_1    = ""   # shared secret tunnel #1
vpn_shared_secret_2    = ""   # shared secret tunnel #2
onprem_network_cidrs   = []   # ví dụ ["192.168.0.0/16"]
